{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "npm run desktop:prepare",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 8888",
    "devPath": "http://localhost:8888",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Simula Desktop",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.laraxgram.simula",
      "resources": [
        "resources/*"
      ]
    },
    "windows": [
      {
        "title": "Simula Desktop",
        "width": 1320,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
